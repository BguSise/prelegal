# Backend Configuration
# IMPORTANT: Generate a secure random key with: python -c "import secrets; print(secrets.token_hex(32))"
# This MUST be set to a 32+ character random string. Never use the placeholder value.
SECRET_KEY=

# Database URL
DATABASE_URL=sqlite:///./data/prelegal.db

# API Configuration
OPENROUTER_API_KEY=

# Frontend (only needed for development with next dev on separate port)
# For local development: NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=/api
